{
  "name": "fut-manager-nextjs-simulator",
  "version": "0.13.1",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:dataset": "cd .. && python3 -m unittest discover -s dataset/tests -p 'test_*.py'",
    "test:all": "npm run typecheck && npm test && npm run test:dataset",
    "test:calibration": "vitest run tests/calibration.test.ts tests/player-match-stats.test.ts tests/analytics-route.test.ts",
    "benchmark:data": "node --import tsx scripts/benchmark-data.ts",
    "calibrate:match": "node --import tsx scripts/calibrate-match.ts",
    "package:data": "node --import tsx scripts/package-data.ts",
    "test:data-package": "node --import tsx scripts/test-data-package.ts"
  },
  "dependencies": {
    "better-sqlite3": "13.0.1",
    "csv-parse": "7.0.1",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.0",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
